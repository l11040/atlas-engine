{
  "name": "desktop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "concurrently -k \"pnpm dev:electron:build\" \"pnpm dev:electron:run\"",
    "dev:electron:build": "concurrently -k \"pnpm --filter @atlas/cli-runtime dev\" \"tsup electron/main.ts electron/preload.ts --format cjs --watch --outDir dist-electron --external electron\"",
    "dev:electron:run": "wait-on tcp:39017 file:dist-electron/main.cjs file:dist-electron/preload.cjs file:../../packages/cli-runtime/dist/index.cjs && nodemon --watch dist-electron --ext cjs --exec \"cross-env ELECTRON_RENDERER_URL=http://localhost:39017 electron dist-electron/main.cjs\"",
    "build": "pnpm --filter @atlas/cli-runtime build && pnpm build:renderer && pnpm build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsup electron/main.ts electron/preload.ts --format cjs --outDir dist-electron --external electron",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "studio": "npx @langchain/langgraph-cli dev"
  },
  "dependencies": {
    "@atlas/cli-runtime": "workspace:*",
    "@langchain/core": "^1.1.27",
    "@langchain/langgraph": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "langsmith": "^0.5.6",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.1.0",
    "wait-on": "^8.0.1"
  }
}
