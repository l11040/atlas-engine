{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ralph Loop State",
  "description": "Ralph Loop 반복 상태",
  "type": "object",
  "required": ["ticket_key", "iteration", "max_iterations", "continue", "updated_at"],
  "properties": {
    "ticket_key": { "type": "string" },
    "iteration": { "type": "integer", "minimum": 1 },
    "max_iterations": { "type": "integer", "minimum": 1 },
    "continue": { "type": "boolean" },
    "completion_criteria": {
      "type": "object",
      "properties": {
        "all_must_done": { "type": "boolean" },
        "all_should_done": { "type": "boolean" },
        "no_failures": { "type": "boolean" }
      }
    },
    "todos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "priority"],
        "properties": {
          "description": { "type": "string" },
          "priority": { "type": "string", "enum": ["MUST", "SHOULD", "MAY"] },
          "source_task_id": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "iteration": { "type": "integer" },
          "tasks_completed": { "type": "integer" },
          "tasks_failed": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
