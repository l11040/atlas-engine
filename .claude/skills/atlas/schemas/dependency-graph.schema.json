{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dependency Graph",
  "description": "Task 간 의존성 DAG",
  "type": "object",
  "required": ["ticket_key", "nodes", "edges"],
  "properties": {
    "ticket_key": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "in_degree", "out_degree"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^TASK-[a-f0-9]{8}$" },
          "in_degree": { "type": "integer", "minimum": 0 },
          "out_degree": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "reason"],
        "properties": {
          "from": { "type": "string", "pattern": "^TASK-[a-f0-9]{8}$" },
          "to": { "type": "string", "pattern": "^TASK-[a-f0-9]{8}$" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
