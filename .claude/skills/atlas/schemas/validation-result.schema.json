{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Validation Result",
  "description": "Task 검증 결과",
  "type": "object",
  "required": ["task_id", "checks", "passed", "validated_at"],
  "properties": {
    "task_id": { "type": "string", "pattern": "^TASK-[a-f0-9]{8}$" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "passed"],
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "message": { "type": "string" },
          "output": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "passed": { "type": "boolean" },
    "validated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
