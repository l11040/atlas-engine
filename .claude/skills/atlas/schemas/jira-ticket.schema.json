{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jira Ticket",
  "description": "파싱된 Jira 티켓 구조",
  "type": "object",
  "required": ["key", "summary", "type", "status"],
  "properties": {
    "key": { "type": "string" },
    "summary": { "type": "string" },
    "description": { "type": ["string", "null"] },
    "type": { "type": "string" },
    "status": { "type": "string" },
    "priority": { "type": "string" },
    "labels": { "type": "array", "items": { "type": "string" } },
    "assignee": { "type": ["string", "null"] },
    "reporter": { "type": ["string", "null"] },
    "parent_key": { "type": ["string", "null"] },
    "subtask_keys": { "type": "array", "items": { "type": "string" } },
    "linked_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "relation": { "type": "string" }
        }
      }
    },
    "acceptance_criteria": { "type": ["string", "null"] },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
