{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "description": "개별 Task 파일. tasks/task-{id}.json 구조.",
  "type": "object",
  "required": ["id", "title", "files", "depends_on", "ac", "status"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "생성/수정할 파일 경로 목록 (PROJECT_ROOT 상대)"
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "의존하는 Task ID 목록"
    },
    "ac": {
      "type": "array",
      "items": { "type": "string" },
      "description": "수용 기준. 'MUST: ...' 또는 'SHOULD: ...' 형식"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "done", "failed"],
      "default": "pending"
    },
    "source_tickets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "이 Task의 근거가 되는 Jira 티켓 키 목록"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "마지막 status 변경 시각 (update_task_status가 자동 설정)"
    }
  },
  "additionalProperties": true
}
