{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "description": "개별 Task 파일. tasks/task-{id}.json 구조.",
  "type": "object",
  "required": ["id", "title", "files", "depends_on", "ac", "status"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "생성/수정할 파일 경로 목록 (PROJECT_ROOT 상대)"
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "의존하는 Task ID 목록"
    },
    "ac": {
      "type": "array",
      "items": { "type": "string" },
      "description": "수용 기준. 'MUST: ...' 또는 'SHOULD: ...' 형식"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "done", "failed"],
      "default": "pending"
    },
    "source_tickets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "이 Task의 근거가 되는 Jira 티켓 키 목록"
    },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["convention", "ac_requires", "decision", "reason"],
        "properties": {
          "convention": { "type": "string", "description": "conventions.json의 해당 규칙 (예: pk_strategy: Long auto-increment)" },
          "ac_requires": { "type": "string", "description": "티켓 AC가 요구하는 값 (예: UUID BINARY(16))" },
          "decision": { "type": "string", "enum": ["ac", "convention"], "description": "어느 쪽을 따를지" },
          "reason": { "type": "string", "description": "판단 근거 (출처 티켓 포함)" }
        }
      },
      "description": "conventions.json과 티켓 AC가 충돌할 때의 명시적 판단. 충돌 없으면 생략."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "마지막 status 변경 시각 (update_task_status가 자동 설정)"
    }
  },
  "additionalProperties": true
}
