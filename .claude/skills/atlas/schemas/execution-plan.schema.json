{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Plan",
  "description": "Wave 기반 실행 계획",
  "type": "object",
  "required": ["ticket_key", "waves", "total_tasks", "created_at"],
  "properties": {
    "ticket_key": { "type": "string" },
    "waves": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wave_index", "task_ids"],
        "properties": {
          "wave_index": { "type": "integer", "minimum": 0 },
          "task_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^TASK-[a-f0-9]{8}$" }
          },
          "parallel": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "total_tasks": { "type": "integer", "minimum": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
