{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conventions",
  "description": "프로젝트 컨벤션 분석 결과. /learn이 생성하고 이후 모든 스텝이 참조한다.",
  "type": "object",
  "required": ["version", "generated_at", "scope", "stack", "naming", "style", "annotations", "patterns", "forbidden", "required", "lint_rules", "domain_lint", "convention_skills_applied", "learned_from_failures"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "scope": {
      "type": "string",
      "description": "이 conventions.json이 적용되는 범위 (예: project-root, server/core, apps/web)"
    },
    "stack": {
      "type": "object",
      "required": ["language", "framework", "build"],
      "properties": {
        "language": { "type": "string", "description": "주 언어 (예: java, typescript, go)" },
        "version": { "type": "string", "description": "언어 버전 (예: 17, 5.3)" },
        "framework": { "type": "string", "description": "주 프레임워크:버전 (예: spring-boot:3.2.1, next:14.1)" },
        "build": { "type": "string", "description": "빌드 도구 (예: gradle, pnpm, cargo)" }
      },
      "additionalProperties": true
    },
    "commands": {
      "type": "object",
      "description": "프로젝트별 빌드/테스트/린트 실행 커맨드. PROJECT_ROOT 기준 상대 경로 포함. learn 단계에서 탐색하여 기록한다.",
      "properties": {
        "build": { "type": "string", "description": "빌드 커맨드 (예: cd server && ./gradlew :core:compileJava)" },
        "test": { "type": "string", "description": "테스트 커맨드 (예: cd server && ./gradlew test)" },
        "lint": { "type": "string", "description": "린트 커맨드 (예: pnpm lint)" },
        "typecheck": { "type": "string", "description": "타입 체크 커맨드 (예: pnpm typecheck)" },
        "format": { "type": "string", "description": "포맷 커맨드 (예: pnpm format)" }
      },
      "additionalProperties": { "type": "string" }
    },
    "naming": {
      "type": "object",
      "description": "네이밍 컨벤션. 키는 대상(entity, service 등), 값은 한 줄 규칙",
      "additionalProperties": { "type": "string" }
    },
    "style": {
      "type": "object",
      "description": "코드 스타일 규칙",
      "properties": {
        "indent": { "type": "string", "description": "예: 4 spaces, 2 spaces, tab" },
        "max_line_length": { "type": "integer" },
        "braces": { "type": "string", "description": "예: same line, next line" },
        "imports": { "type": "string", "description": "예: no wildcard, static imports last" }
      },
      "additionalProperties": { "type": "string" }
    },
    "annotations": {
      "type": "object",
      "description": "레이어별 자주 사용되는 어노테이션/데코레이터 목록",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "patterns": {
      "type": "object",
      "description": "프로젝트에서 사용하는 디자인/구현 패턴. 키는 패턴명, 값은 한 줄 설명",
      "additionalProperties": { "type": "string" }
    },
    "forbidden": {
      "type": "array",
      "description": "하면 안 되는 것 — 명시적 금지 목록. 한 줄로 명확하게",
      "items": { "type": "string" }
    },
    "required": {
      "type": "array",
      "description": "반드시 해야 하는 것 — 명시적 필수 목록. 한 줄로 명확하게",
      "items": { "type": "string" }
    },
    "lint_rules": {
      "type": "object",
      "properties": {
        "source": { "type": "string", "description": "린트 설정 파일 경로 (예: .checkstyle.xml, .eslintrc.js)" },
        "key_rules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "핵심 린트 규칙 요약"
        }
      },
      "additionalProperties": false
    },
    "production_rules": {
      "type": "object",
      "description": "도메인 구조 결함 방지 규칙. 레드팀 체크리스트에서 참조한다. 카테고리는 프로젝트 스택에 따라 자유롭게 정의한다.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" },
        "description": "카테고리별 규칙 목록. 한 줄로 명확하게. 예: 'mutable balance fields must have optimistic locking'"
      }
    },
    "domain_lint": {
      "type": "array",
      "description": "validate.sh --domain-lint에서 실행하는 선언적 룰. learn 단계에서 프로젝트 코드를 분석하여 생성한다. 스택에 무관한 3가지 룰 타입을 지원한다.",
      "items": {
        "type": "object",
        "required": ["id", "type", "file_glob", "trigger", "message"],
        "properties": {
          "id": { "type": "string", "description": "룰 식별자 (예: CONC-1, RESERVED-1)" },
          "type": {
            "type": "string",
            "enum": ["require_guard", "forbidden_name", "method_guard"],
            "description": "require_guard: trigger+condition이면 guard 필수. forbidden_name: trigger에서 추출한 이름이 forbidden 목록에 없어야 함. method_guard: 특정 메서드에 guard 코드 필수."
          },
          "file_glob": { "type": "string", "description": "대상 파일 패턴 (예: *.java, *.ts, *.go, *.py)" },
          "trigger": { "type": "string", "description": "검사 대상 파일을 찾는 grep 패턴 (예: @Entity, class.*Model, type.*struct)" },
          "condition": { "type": "string", "description": "[require_guard] trigger 파일 중 이 패턴도 있어야 검사 대상" },
          "guard": { "type": "string", "description": "[require_guard] 이 패턴이 없으면 위반" },
          "exclude": { "type": "string", "description": "이 ERE 패턴에 매칭되는 파일은 제외 (예: @Immutable|append-only)" },
          "name_attr": { "type": "string", "description": "[forbidden_name] 추출할 속성명 (예: name, tableName)" },
          "forbidden": { "type": "array", "items": { "type": "string" }, "description": "[forbidden_name] 금지된 값 목록 (소문자 비교)" },
          "prerequisite": { "type": "string", "description": "[method_guard] 이 패턴이 있는 파일만 검사" },
          "method_pattern": { "type": "string", "description": "[method_guard] 검사할 메서드명 ERE 패턴" },
          "guard_pattern": { "type": "string", "description": "[method_guard] 메서드 내부에 이 패턴이 없으면 위반" },
          "method_visibility": { "type": "string", "description": "[method_guard] 메서드 가시성 키워드 (기본: public)" },
          "message": { "type": "string", "description": "위반 시 출력 메시지" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"], "default": "high" }
        },
        "additionalProperties": false
      }
    },
    "convention_skills_applied": {
      "type": "array",
      "description": "Layer 2에서 감지·적용된 외부 컨벤션 스킬 목록",
      "items": { "type": "string" }
    },
    "learned_from_failures": {
      "type": "array",
      "description": "Review 실패로 추가된 규칙 추적 로그. 초기 생성 시 빈 배열",
      "items": {
        "type": "object",
        "required": ["rule", "added_to", "learned_at", "source"],
        "properties": {
          "rule": { "type": "string" },
          "added_to": { "type": "string", "enum": ["required", "forbidden", "production_rules"] },
          "learned_at": { "type": "string", "format": "date-time" },
          "source": { "type": "string", "description": "예: TASK-abc12345 review failure" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
