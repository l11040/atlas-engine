{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Policy Registry",
  "description": "Story 레벨 Policy Rules를 추적하는 레지스트리. /analyze가 생성하고 /execute, /complete가 status를 갱신한다.",
  "type": "object",
  "required": ["ticket_key", "generated_at", "policies", "coverage"],
  "properties": {
    "ticket_key": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "policies": {
      "type": "object",
      "description": "Policy Rules. 키는 Policy ID (예: POL-EARN-001)",
      "additionalProperties": {
        "$ref": "#/$defs/policy_entry"
      }
    },
    "coverage": {
      "type": "object",
      "required": ["total", "implemented", "tested"],
      "properties": {
        "total": { "type": "integer", "description": "전체 Policy 수" },
        "implemented": { "type": "integer", "description": "impl Task에 매핑된 Policy 수" },
        "tested": { "type": "integer", "description": "test Task에 매핑된 Policy 수" },
        "gaps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "어떤 Task에도 매핑되지 않은 Policy ID 목록"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "policy_entry": {
      "type": "object",
      "required": ["text", "level", "source_story", "status"],
      "properties": {
        "text": { "type": "string", "description": "Policy 원문" },
        "level": { "type": "string", "enum": ["MUST", "SHOULD", "MAY"] },
        "source_story": { "type": "string", "description": "Policy가 정의된 Story Jira 키" },
        "defaults": {
          "type": "object",
          "description": "Policy 기본값 (예: rate_type=percentage)",
          "additionalProperties": true
        },
        "implemented_by": {
          "type": "array",
          "items": { "type": "string", "pattern": "^TASK-[a-f0-9]{8}$" },
          "description": "이 Policy를 구현하는 impl Task ID 목록"
        },
        "tested_by": {
          "type": "array",
          "items": { "type": "string", "pattern": "^TASK-[a-f0-9]{8}$" },
          "description": "이 Policy를 검증하는 test Task ID 목록"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "verified", "failed"],
          "description": "analyze=pending, execute=in_progress, complete=verified/failed"
        }
      },
      "additionalProperties": false
    }
  }
}
