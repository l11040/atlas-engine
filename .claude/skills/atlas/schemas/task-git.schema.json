{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Git",
  "description": "Task의 git commit 정보",
  "type": "object",
  "required": ["task_id", "commit_hash", "branch", "committed_at"],
  "properties": {
    "task_id": { "type": "string", "pattern": "^TASK-[a-f0-9]{8}$" },
    "commit_hash": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "branch": { "type": "string" },
    "base_head": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "committed_at": { "type": "string", "format": "date-time" },
    "diff_stat": {
      "type": "object",
      "properties": {
        "files_changed": { "type": "integer", "minimum": 0 },
        "insertions": { "type": "integer", "minimum": 0 },
        "deletions": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "additionalProperties": false
}
