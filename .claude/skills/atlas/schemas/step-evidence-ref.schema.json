{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Step Evidence Reference",
  "description": "공유 증거를 참조하여 스킵한 스텝의 참조 기록 파일",
  "type": "object",
  "required": ["step", "status", "referenced_at", "source", "source_validated_at"],
  "properties": {
    "step": {
      "type": "string",
      "enum": ["learn"]
    },
    "status": {
      "type": "string",
      "const": "referenced"
    },
    "referenced_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "string",
      "description": "참조한 공유 증거 파일 경로"
    },
    "source_validated_at": {
      "type": "string",
      "format": "date-time",
      "description": "공유 증거의 validated_at 값"
    }
  },
  "additionalProperties": false
}
