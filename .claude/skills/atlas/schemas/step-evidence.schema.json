{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Step Evidence",
  "description": "스텝 완료 후 post-step Hook이 생성하는 검증 증거 파일",
  "type": "object",
  "required": ["step", "status", "validated_at", "outputs"],
  "properties": {
    "step": {
      "type": "string",
      "enum": ["learn", "analyze", "plan", "execute", "complete"]
    },
    "status": {
      "type": "string",
      "enum": ["validated", "failed"]
    },
    "validated_at": { "type": "string", "format": "date-time" },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file", "schema", "valid"],
        "properties": {
          "file": { "type": "string", "description": "검증 대상 파일 경로" },
          "schema": { "type": "string", "description": "사용된 스키마 이름" },
          "valid": { "type": "boolean" },
          "error": { "type": "string", "description": "검증 실패 시 에러 메시지" }
        },
        "additionalProperties": false
      }
    },
    "duration_ms": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
