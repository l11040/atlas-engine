{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RedTeamSummary",
  "description": "레이어별 레드팀 결과 요약",
  "type": "object",
  "required": ["type", "task_id", "layers", "total_fixes", "timestamp"],
  "properties": {
    "type": { "type": "string", "const": "redteam_summary" },
    "task_id": { "type": "string" },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["layer", "pass", "fail"],
        "properties": {
          "layer": {
            "type": "string",
            "enum": ["domain", "schema", "repository", "service", "batch", "controller", "dto", "test"],
            "description": "레이어명. 프로젝트 스택에 따라 확장 가능"
          },
          "pass": { "type": "integer", "minimum": 0 },
          "fail": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "total_fixes": { "type": "integer", "minimum": 0 },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
