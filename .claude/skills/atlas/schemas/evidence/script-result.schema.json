{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScriptResult",
  "description": "스크립트 실행 성공 기록",
  "type": "object",
  "required": ["type", "script", "exit_code", "timestamp"],
  "properties": {
    "type": { "type": "string", "enum": ["script", "validate_result"], "description": "script(범용) 또는 validate_result(validate.sh)" },
    "script": { "type": "string" },
    "args": { "type": "array", "items": { "type": "string" } },
    "exit_code": { "type": "integer" },
    "status": { "type": "string", "enum": ["pass", "fail"], "description": "validate.sh 결과 (pass/fail)" },
    "taxonomy": { "type": "string", "description": "실패 분류 (pass, scope_violation, compile_error, lint_violation, domain_lint)" },
    "output_summary": { "type": "string" },
    "output_tail": { "type": "string", "description": "실패 시 stderr 요약" },
    "gate_failed": { "type": "string", "description": "실패한 게이트 이름" },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "task_id": { "type": "string" },
    "gates_passed": { "type": "array", "items": { "type": "string" } },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
