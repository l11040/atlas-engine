{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConventionCheck",
  "description": "convention-check 결과 기록. record-convention-evidence.sh가 생성한다.",
  "type": "object",
  "required": ["type", "task_id", "skills_applied", "checks", "summary", "timestamp"],
  "properties": {
    "type": { "type": "string", "const": "convention_check" },
    "task_id": { "type": "string" },
    "skills_applied": {
      "type": "array",
      "items": { "type": "string" },
      "description": "실행된 convention 스킬 ID 목록"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rule", "status", "evidence"],
        "properties": {
          "id": { "type": "string", "description": "체크 항목 식별자 (예: ENT-01, ENUM-01)" },
          "rule": { "type": "string", "description": "검증 규칙 설명" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "SKIP"] },
          "evidence": { "type": "string", "description": "판정 근거 (파일:라인 또는 설명)" },
          "fix_hint": { "type": "string", "description": "FAIL 시 수정 힌트" }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "pass", "fail", "pass_rate"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "skip": { "type": "integer", "minimum": 0 },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
