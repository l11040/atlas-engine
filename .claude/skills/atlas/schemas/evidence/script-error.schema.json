{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScriptError",
  "description": "스크립트 실행 오류 기록. 모든 스크립트 실패 시 반드시 생성.",
  "type": "object",
  "required": ["type", "script", "exit_code", "stderr", "diagnosis", "timestamp"],
  "properties": {
    "type": { "type": "string", "const": "script_error" },
    "script": { "type": "string" },
    "args": { "type": "array", "items": { "type": "string" } },
    "exit_code": { "type": "integer" },
    "gate_failed": { "type": "string", "description": "validate.sh 실패 시 어떤 게이트인지" },
    "stderr": { "type": "string", "maxLength": 2000 },
    "stdout": { "type": "string" },
    "task_id": { "type": "string" },
    "diagnosis": { "type": "string", "description": "LLM이 분석한 오류 원인" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
