{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RedTeam",
  "description": "레이어별 레드팀 검토 기록. 모든 체크 항목은 line_ref(파일:라인)를 반드시 포함해야 한다.",
  "type": "object",
  "required": ["type", "target", "layer", "checks", "timestamp"],
  "properties": {
    "type": { "type": "string", "const": "redteam" },
    "target": { "type": "string", "description": "검토 대상 증거 파일명" },
    "layer": {
      "type": "string",
      "description": "검토 레이어. 프로젝트 스택에 따라 자유롭게 정의 (예: domain, schema, repository, service, batch, component, api, middleware)"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "item", "result", "line_ref"],
        "properties": {
          "id": {
            "type": "string",
            "description": "체크 항목 식별자 (예: CONC-1, STATE-1, AUDIT-1)"
          },
          "item": { "type": "string", "description": "검토 항목 설명" },
          "result": { "type": "string", "enum": ["pass", "fail", "skip"] },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "위반 심각도 (fail일 때 필수)"
          },
          "line_ref": {
            "type": "string",
            "description": "증거 위치 — pass: 조건 충족 코드, fail: 위반 코드, skip: 'N/A'. 형식: FileName.java:42"
          },
          "detail": { "type": "string", "description": "상세 설명 또는 수정 지시" }
        },
        "additionalProperties": false
      }
    },
    "fixes_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "수정 대상 체크 ID" },
          "description": { "type": "string" },
          "line_ref": { "type": "string", "description": "수정이 적용된 위치" }
        },
        "required": ["id", "description"],
        "additionalProperties": false
      },
      "description": "수정한 내역"
    },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
