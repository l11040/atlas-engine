{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditSummary",
  "description": "전체 카테고리 감사 결과 요약",
  "type": "object",
  "required": ["type", "categories", "total_violations", "total_fixes", "timestamp"],
  "properties": {
    "type": { "type": "string", "const": "audit_summary" },
    "files_audited_count": {
      "type": "integer",
      "minimum": 0,
      "description": "감사 대상 파일 수"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "pass", "fail"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["naming", "style", "annotations", "patterns", "forbidden", "required"]
          },
          "pass": { "type": "integer", "minimum": 0 },
          "fail": { "type": "integer", "minimum": 0 },
          "skip": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "total_violations": {
      "type": "object",
      "required": ["high", "medium", "low"],
      "properties": {
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "total_fixes": { "type": "integer", "minimum": 0 },
    "fix_commit": {
      "type": "string",
      "description": "수정 커밋 해시 (수정이 있을 때만)"
    },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
