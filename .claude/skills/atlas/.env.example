# ── 프로젝트 설정 ──
PROJECT_ROOT=/path/to/target/project       # 자동화 대상 프로젝트 경로
AUTOMATION_DIR=.automation                  # 상태 저장 디렉토리 (기본값)

# ── Jira API ──
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=                             # Jira API 토큰 (Personal Access Token)
JIRA_PROJECT_KEY=GRID                       # 프로젝트 키 (예: GRID, PROJ)

# ── Ralph Loop ──
RALPH_MAX_ITERATIONS=10                     # 최대 반복 횟수
RALPH_AUTO_APPROVE=false                    # true: 자동 승인, false: 매 iteration 확인

# ── 알림 ──
NOTIFY_METHOD=console                       # console | slack | email
SLACK_WEBHOOK_URL=                          # Slack 알림 시
NOTIFY_EMAIL=                               # Email 알림 시

# ── 실행 옵션 ──
MAX_PARALLEL_TASKS=4                        # Phase 1/2 병렬 Task 수 제한
TASK_TIMEOUT_MS=300000                      # Task별 타임아웃 (5분)
HOOK_TIMEOUT_MS=10000                       # Hook 타임아웃 (10초)