{
  "_doc": "스텝별 파일 권한 정책. LLM의 Write/Edit 대상을 제한한다.",

  "global": {
    "no_access": [
      ".env",
      ".env.*"
    ],
    "readonly": [
      ".claude/skills/atlas/schemas/**",
      ".claude/skills/atlas/scripts/**",
      ".claude/skills/atlas/hooks/**",
      ".claude/skills/atlas/skills/*/SKILL.md",
      ".claude/skills/atlas/skills/*/scripts/**",
      ".claude/skills/atlas/references/**",
      ".claude/skills/atlas/SKILL.md"
    ]
  },

  "steps": {
    "learn": {
      "writable": [
        ".automation/conventions.json",
        ".automation/evidence/learn.*"
      ]
    },
    "analyze": {
      "writable": [
        "${RUN_DIR}/**"
      ]
    },
    "plan": {
      "writable": [
        "${RUN_DIR}/dependency-graph.json",
        "${RUN_DIR}/execution-plan.json",
        "${RUN_DIR}/policy-registry.json",
        "${RUN_DIR}/evidence/plan.*",
        "${RUN_DIR}/tasks/*/meta/task.json"
      ]
    },
    "execute": {
      "writable": [
        "${PROJECT_ROOT}/**",
        "${RUN_DIR}/tasks/*/state/**",
        "${RUN_DIR}/tasks/*/artifacts/**",
        "${RUN_DIR}/tasks/*/meta/task.json",
        "${RUN_DIR}/tasks/*/validation/**",
        "${RUN_DIR}/evidence/execute.*",
        "${RUN_DIR}/errors/**"
      ],
      "writable_exclude": [
        ".claude/**",
        ".automation/conventions.json",
        ".automation/runs.json"
      ]
    }
  }
}
